<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/google_map"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/tv_zone_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:background="#198754"
            android:padding="12dp"
            android:text="Locating..."
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:elevation="4dp"/>

        <!-- ✨ NEW: The Active Timer Floating Widget -->
        <include layout="@layout/widget_active_safewalk" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:orientation="horizontal"
            android:padding="16dp"
            android:elevation="4dp">

            <Button
                android:id="@+id/btn_share_location"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:backgroundTint="#0D6EFD"
                android:text="Share Link"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btn_sos"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:backgroundTint="#DC3545"
                android:text="🚨 SOS"
                android:visibility="gone"/>
        </LinearLayout>

    </RelativeLayout>

    <!-- The original Danger Zone Bottom Sheet -->
    <include layout="@layout/bottom_sheet_risk_zone" />

    <!-- ✨ NEW: The SafeWalk Setup Bottom Sheet -->
    <include layout="@layout/bottom_sheet_safewalk" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>