<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_centerVertical="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Admin Control Room"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#0D1B2A"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BeSafe — DUT Campus Safety"
                    android:textSize="12sp"
                    android:textColor="#6C757D"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_admin_logout"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="Sign Out"
                android:textColor="#DC3545"
                app:icon="@android:drawable/ic_lock_power_off"
                app:iconTint="#DC3545"/>
        </RelativeLayout>

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleStatFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:checkedButton="@+id/btnStatToday">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStatToday"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Today"
                android:textSize="12sp"
                app:cornerRadius="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStatWeek"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="7 Days"
                android:textSize="12sp"
                app:cornerRadius="0dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStatMonth"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="30 Days"
                android:textSize="12sp"
                app:cornerRadius="8dp"/>
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="👥 Users" android:textSize="12sp" android:textColor="#6C757D"/>
                    <TextView android:id="@+id/tvTotalUsers"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textSize="28sp" android:textStyle="bold"
                        android:textColor="#0D6EFD"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Registered" android:textSize="10sp" android:textColor="#ADB5BD"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🚨 SOS" android:textSize="12sp" android:textColor="#6C757D"/>
                    <TextView android:id="@+id/tvSosToday"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textSize="28sp" android:textStyle="bold"
                        android:textColor="#DC3545"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="In period" android:textSize="10sp" android:textColor="#ADB5BD"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📋 Reports" android:textSize="12sp" android:textColor="#6C757D"/>
                    <TextView android:id="@+id/tvTotalReports"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textSize="28sp" android:textStyle="bold"
                        android:textColor="#198754"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Filed" android:textSize="10sp" android:textColor="#ADB5BD"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⚡ Active" android:textSize="12sp" android:textColor="#6C757D"/>
                    <TextView android:id="@+id/tvActiveAlerts"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textSize="28sp" android:textStyle="bold"
                        android:textColor="#FD7E14"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Right now" android:textSize="10sp" android:textColor="#ADB5BD"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✅ Resolved" android:textSize="12sp" android:textColor="#6C757D"/>
                    <TextView android:id="@+id/tvResolvedCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textSize="28sp" android:textStyle="bold"
                        android:textColor="#6F42C1"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Total closed" android:textSize="10sp" android:textColor="#ADB5BD"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⏱ Avg Response" android:textSize="12sp" android:textColor="#6C757D"/>
                    <TextView android:id="@+id/tvAvgResponse"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="--" android:textSize="22sp" android:textStyle="bold"
                        android:textColor="#0D6EFD"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Guard dispatch" android:textSize="10sp" android:textColor="#ADB5BD"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recent Incidents"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#0D1B2A"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:id="@+id/layoutRecentIncidents"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Send Campus Broadcast"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#0D1B2A"
                    android:layout_marginBottom="12dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="10dp"
                    android:hint="Broadcast Title (e.g. Weather Alert)">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etBroadcastTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="12dp"
                    android:hint="Type your message here...">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etBroadcastMessage"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:gravity="top|start"/>
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Target Audience"
                    android:textSize="12sp"
                    android:textColor="#6C757D"
                    android:layout_marginBottom="6dp"/>

                <Spinner
                    android:id="@+id/spinnerAudience"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@android:drawable/btn_dropdown"
                    android:layout_marginBottom="16dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSendBroadcast"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="SEND BROADCAST NOW"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:icon="@android:drawable/ic_dialog_email"
                    app:backgroundTint="#FF9800"
                    app:cornerRadius="12dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>