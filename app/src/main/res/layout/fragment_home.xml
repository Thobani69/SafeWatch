<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bs_bg_page"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="48dp">

        <!-- THEME TOGGLE PILL (Top Right) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnThemeToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="24dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/bs_report_bg"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeColor="@color/bs_report_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/ivThemeIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_theme"
                    android:contentDescription="Theme icon" />

                <TextView
                    android:id="@+id/tvThemeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dark"
                    android:textColor="@color/bs_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- STATUS TEXT -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Status: SYSTEM READY"
            android:textAlignment="center"
            android:textColor="@color/bs_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- MASSIVE SOS BUTTON & RINGS -->
        <View
            android:id="@+id/sos_ring_outer"
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/circle_bg"
            android:backgroundTint="@color/bs_sos_ring_outer"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvStatus" />

        <View
            android:id="@+id/sos_ring_mid"
            android:layout_width="270dp"
            android:layout_height="270dp"
            android:background="@drawable/circle_bg"
            android:backgroundTint="@color/bs_sos_ring_mid"
            app:layout_constraintBottom_toBottomOf="@id/sos_ring_outer"
            app:layout_constraintEnd_toEndOf="@id/sos_ring_outer"
            app:layout_constraintStart_toStartOf="@id/sos_ring_outer"
            app:layout_constraintTop_toTopOf="@id/sos_ring_outer" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSos"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:text="SOS"
            android:textSize="56sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:backgroundTint="#DC3545"
            app:cornerRadius="110dp"
            app:layout_constraintBottom_toBottomOf="@id/sos_ring_mid"
            app:layout_constraintEnd_toEndOf="@id/sos_ring_mid"
            app:layout_constraintStart_toStartOf="@id/sos_ring_mid"
            app:layout_constraintTop_toTopOf="@id/sos_ring_mid" />

        <TextView
            android:id="@+id/tvSosHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Press and HOLD to trigger"
            android:textColor="@color/bs_sos_hint"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/sos_ring_outer" />

        <!-- INCIDENT REPORTING CARDS -->
        <LinearLayout
            android:id="@+id/layout_reports"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tvSosHint">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnReportIssue"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/bs_report_bg"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/bs_report_border"
                app:strokeWidth="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="20dp"
                    android:text="Report\nIssue"
                    android:textAlignment="center"
                    android:textColor="@color/bs_report_title"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnViewReports"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/bs_report_bg"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/bs_report_border"
                app:strokeWidth="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="20dp"
                    android:text="View\nReports"
                    android:textAlignment="center"
                    android:textColor="@color/bs_report_title"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- EMERGENCY DIRECTORY SECTION -->
        <TextView
            android:id="@+id/tvDirectoryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:text="Emergency Directory"
            android:textColor="@color/bs_text_secondary"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_reports" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp"
            android:columnCount="2"
            android:rowCount="2"
            app:layout_constraintTop_toBottomOf="@id/tvDirectoryTitle">

            <!-- Control -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_call_control"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/bs_contact_red_bg"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/bs_contact_red_border"
                app:strokeWidth="1dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="Campus\nControl"
                    android:textColor="@color/bs_contact_red_title"
                    android:textStyle="bold"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- WhatsApp -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_whatsapp_security"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/bs_contact_grn_bg"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/bs_contact_grn_border"
                app:strokeWidth="1dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="WhatsApp\nSecurity"
                    android:textColor="@color/bs_contact_grn_title"
                    android:textStyle="bold"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- SAPS -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_call_saps"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/bs_contact_blu_bg"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/bs_contact_blu_border"
                app:strokeWidth="1dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="National\nSAPS"
                    android:textColor="@color/bs_contact_blu_title"
                    android:textStyle="bold"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Clinic -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_call_clinic"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginStart="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/bs_contact_amb_bg"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/bs_contact_amb_border"
                app:strokeWidth="1dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="Campus\nClinic"
                    android:textColor="@color/bs_contact_amb_title"
                    android:textStyle="bold"/>
            </com.google.android.material.card.MaterialCardView>
        </GridLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>