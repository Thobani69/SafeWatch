<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_active_safewalk"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="80dp"
    app:cardBackgroundColor="#212529"
    app:cardCornerRadius="12dp"
    app:cardElevation="8dp"
    android:visibility="gone"> <!-- Hidden by default until walk starts -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Info Section -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_active_destination"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Walking to Main Library"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_active_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="14:59"
                android:textColor="#FFC107"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- The Arrived Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_im_safe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#198754"
            android:text="✅ I'm Safe"
            android:textColor="#FFFFFF"
            app:cornerRadius="8dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>