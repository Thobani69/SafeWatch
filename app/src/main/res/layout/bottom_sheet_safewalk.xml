<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottom_sheet_safewalk"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:elevation="16dp"
    android:orientation="vertical"
    android:padding="24dp"
    app:behavior_hideable="true"
    app:behavior_peekHeight="0dp"
    app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="#E0E0E0" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🛡️ SafeWalk Setup"
        android:textColor="#212529"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp"
        android:text="Set your destination and estimated walk time."
        android:textColor="#6C757D"
        android:textSize="14sp" />

    <!-- Local Destination Search (No API Required!) -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Where are you going?">

        <AutoCompleteTextView
            android:id="@+id/actv_destination"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Timer Duration Section (Replaces CircularSeekBar with Material Slider) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp">

        <!-- Centered Timer Display -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_dial_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15"
                android:textColor="#0D6EFD"
                android:textSize="48sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Minutes"
                android:textColor="#6C757D"
                android:textSize="16sp" />

        </LinearLayout>
    </FrameLayout>

    <!-- Material Slider (replaces the broken CircularSeekBar) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Slide to adjust duration"
        android:textColor="#6C757D"
        android:textSize="13sp"
        android:layout_marginBottom="8dp"
        android:gravity="center" />

    <com.google.android.material.slider.Slider
        android:id="@+id/slider_timer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:valueFrom="1"
        android:valueTo="60"
        android:value="15"
        android:stepSize="1"
        app:thumbColor="#0D6EFD"
        app:trackColorActive="#0D6EFD"
        app:trackColorInactive="#EEEEEE"
        app:haloColor="#400D6EFD"
        app:tickColor="#0D6EFD"
        android:layout_marginBottom="4dp" />

    <!-- Min / Max Labels -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1 min"
            android:textSize="12sp"
            android:textColor="#6C757D" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="60 min"
            android:textSize="12sp"
            android:textColor="#6C757D"
            android:gravity="end" />

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_start_safewalk"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Start Walk"
        android:textSize="16sp"
        app:cornerRadius="8dp" />

</LinearLayout>