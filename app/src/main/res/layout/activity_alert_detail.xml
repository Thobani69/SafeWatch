<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- Full-screen map underneath everything -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/detail_map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Back button (top-left, floats over map) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btn_back_container"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:strokeWidth="0dp">
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:padding="12dp"
            app:tint="#212529"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- ✅ NEW: Student profile card — shown to security only, hidden for students -->
    <!-- Floats above the bottom controls card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/student_profile_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="220dp"
        android:visibility="gone"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:strokeWidth="1dp"
        app:strokeColor="#FFE0E0">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp">

            <!-- Avatar circle -->
            <ImageView
                android:id="@+id/iv_student_avatar"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@android:drawable/ic_menu_gallery"
                android:background="#FFCCCC"
                android:padding="8dp"
                android:scaleType="centerCrop"
                android:layout_marginEnd="14dp"/>

            <!-- Student details -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_student_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#212529"/>

                <TextView
                    android:id="@+id/tv_student_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="#6C757D"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/tv_student_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="#6C757D"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/tv_student_phone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#DC3545"
                    android:layout_marginTop="3dp"/>
            </LinearLayout>

            <!-- SOS badge -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#DC3545"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SOS"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"/>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom controls card (Dispatch + Resolve buttons) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottom_controls_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="28dp"
        app:cardElevation="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Status badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="#FDEAEA"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginBottom="20dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="center"
                    android:background="#DC3545"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/tv_alert_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACTIVE EMERGENCY"
                    android:textColor="#DC3545"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>
            </LinearLayout>

            <!-- Dispatch button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_dispatch"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="DISPATCH UNIT"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#0D6EFD"
                android:layout_marginBottom="12dp"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_dialog_map"
                app:iconGravity="textStart"/>

            <!-- Resolve button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_resolve"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="MARK AS RESOLVED"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#198754"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/checkbox_on_background"
                app:iconGravity="textStart"
                app:iconTint="#198754"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</RelativeLayout>