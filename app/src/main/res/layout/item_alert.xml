<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:strokeColor="#DC3545"
    app:strokeWidth="1.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFF9F9"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚨 ACTIVE SOS"
                android:textColor="#DC3545"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAlertId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="#TICKET"
                android:textColor="#6C757D"
                android:textSize="14sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E9ECEF"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvReporterEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reporter: Loading..."
            android:textColor="#212529"
            android:textSize="15sp"
            android:textStyle="bold"
            app:drawableStartCompat="@android:drawable/ic_menu_myplaces"
            android:drawablePadding="8dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvAlertLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lat: 0.0 \nLon: 0.0"
            android:textColor="#495057"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvAlertTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time recorded: ..."
            android:textColor="#ADB5BD"
            android:textSize="12sp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>